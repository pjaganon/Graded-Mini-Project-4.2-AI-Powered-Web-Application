# Copy this file to `.env` in the project root, then paste your key below.
# Get a key from: https://aistudio.google.com/apikey
# New keys may start with "AQ." (auth key) or "AIza" (legacy) — both work here.
GEMINI_API_KEY="your-gemini-api-key-here"

# Optional — used for hosted deployments
APP_URL="http://localhost:3000"
